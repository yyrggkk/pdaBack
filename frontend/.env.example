# STITCH - Restaurant POS App
# Frontend Environment Variables
# Copy this file to .env and update the values

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (Laravel)
# - For local development, use your machine's IP address (not localhost)
# - Find your IP: ipconfig getifaddr en0 (Mac) or ipconfig (Windows)

EXPO_PUBLIC_API_URL=http://YOUR_IP_ADDRESS:8000/api

# =============================================================================
# Usage Instructions
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Get your local IP address:
#    - Mac/Linux: ipconfig getifaddr en0
#    - Windows: ipconfig (look for IPv4 Address)
#
# 3. Update EXPO_PUBLIC_API_URL with your IP
#
# 4. Start the backend:
#    cd backend
#    php artisan serve --host=YOUR_IP_ADDRESS --port=8000
#
# 5. Start the frontend:
#    cd frontend
#    npx expo start -c
#
# =============================================================================
